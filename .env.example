# Configuración de Servidor
PORT=8000

# Base de Datos - PostgreSQL
# Ejemplo con Cloud SQL: postgresql://user:password@/database?host=/cloudsql/project:region:instance
DATABASE_URL="postgresql://postgres:password@localhost:5432/facturatrs"

# Configuración JWT
SECRET_KEY="tu_clave_secreta_jwt_aqui"

# Configuración de Alanube
ALANUBE_API_URL="https://sandbox.alanube.co/dom/v1/"
ALANUBE_TOKEN="TU_TOKEN_DE_ALANUBE_AQUI"

# Configuración de GAE (Signature)
GAE_API_URL="https://fe.gaedigital.com/SignatureServices/api/"
GAE_API_KEY="TU_API_KEY_DE_GAE_AQUI"

# Storage local
STORAGE_PATH="./storage"

# Cloud Storage (Backblaze B2 - S3 compatible)
CLOUD_STORAGE_ENABLED=false
B2_ENDPOINT=""
B2_REGION="us-west-004"
B2_ACCESS_KEY=""
B2_SECRET_KEY=""
B2_BUCKET="facturatrs-backup"
